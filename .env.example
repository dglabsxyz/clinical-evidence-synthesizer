# Copy these into Replit Secrets (Tools -> Secrets). Do NOT commit real keys.
DASHSCOPE_API_KEY=your_model_studio_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
# DATABASE_URL is added automatically by Replit when you provision Postgres.
# Optional override if your Model Studio account is not in Singapore:
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
